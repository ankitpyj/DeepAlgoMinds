class Solution(object):
    def maxSlidingWindow(self, nums, k):
        listt = []

        n= len(nums)
        for i in range(0,n-k+1):
            maxi = nums[i]

            for j in range(i,i+k):
                maxi = max(maxi,nums[j])

            listt.append(maxi)

        return listt

        
        
